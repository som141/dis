COMPOSE_PROJECT_NAME=discord-bot
GATEWAY_IMAGE_NAME=discord-gateway
GATEWAY_IMAGE_TAG=local
AUDIO_NODE_IMAGE_NAME=discord-audio-node
AUDIO_NODE_IMAGE_TAG=local
STOCK_NODE_IMAGE_NAME=discord-stock-node
STOCK_NODE_IMAGE_TAG=local
APP_ENV=local
OBSERVABILITY_ENABLED=true
DISCORD_TOKEN=replace-with-your-discord-bot-token
DISCORD_DEV_GUILD_ID=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_OAUTH_INIT=false
YOUTUBE_PO_TOKEN=
YOUTUBE_VISITOR_DATA=
YOUTUBE_REMOTE_CIPHER_URL=
YOUTUBE_REMOTE_CIPHER_PASSWORD=
YOUTUBE_REMOTE_CIPHER_USER_AGENT=
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
POSTGRES_DB=stock
POSTGRES_USER=stock
POSTGRES_PASSWORD=stock
STOCK_QUOTE_PROVIDER=mock
STOCK_QUOTE_CACHE_TTL=60s
STOCK_QUOTE_FRESHNESS=45s
STOCK_QUOTE_TRADE_FRESHNESS=45s
STOCK_PROVIDER_PER_MINUTE_LIMIT=60
STOCK_PROVIDER_PER_DAY_LIMIT=100000
STOCK_MARKET_DATA_ENABLED=true
STOCK_MARKET=US
STOCK_MARKET_REFRESH_DELAY_MS=20000
STOCK_TOP_RANK_LIMIT=10
FINNHUB_BASE_URL=https://finnhub.io/api/v1
FINNHUB_API_KEY=
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ANONYMOUS_ENABLED=false
GRAFANA_ALERT_DEFAULT_RECEIVER=observability-noop
GRAFANA_ALERT_NOOP_WEBHOOK_URL=http://127.0.0.1:9/disabled
GRAFANA_ALERT_DISCORD_WEBHOOK_URL=https://example.invalid/discord-webhook
GRAFANA_ALERT_DISCORD_AVATAR_URL=
GRAFANA_ALERT_DISCORD_USE_USERNAME=true
GRAFANA_IMAGE=
PROMETHEUS_IMAGE=
LOKI_IMAGE=
ALLOY_IMAGE=
REDIS_EXPORTER_IMAGE=
